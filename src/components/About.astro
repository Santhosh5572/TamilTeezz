<section id="about" class="py-20 bg-black">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Text Content -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">
