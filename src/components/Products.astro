---
const products = [
 { name: "King Was Born On April ", price: "599", image: "/t10.jpeg" },
     { name: "VR 46 ROSSI ", price: "599", image: "/t11.jpeg" },
     { name: "Eminem ", price: "599", image: "/t12.jpeg" },
     { name: "Daft Punk ", price: "599", image: "/t13.jpeg" },  
{ name: "One Last Dance", price: "599", image: "/t9.jpeg" },
  { name: "Attack On Titan", price: "549", image: "/t6.jpeg" },
  { name: "Lord Ayyapan", price: "599", image: "/t4.jpeg" },
   { name: "TVK ", price: "599", image: "/t7.jpeg" },
    { name: "Monkey D LUffy", price: "599", image: "/t5.jpeg" },
    //  { name: "Hack The Box ", price: "799", image: "/t3.jpeg" },
    
];
---

<section id="products" class="pt-20 pb-20 px-8 max-w-7xl mx-auto">
  <h2 class="text-6xl text-[#34D399] font-bold mb-20 text-center tracking-wide">
    THE COLLECTION
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-14">
    {products.map(product => (
      <div class="group bg-[#111] rounded-2xl overflow-hidden border border-white/10">
        <img
          src={product.image}
          alt={product.name}
          class="w-full h-[420px] object-cover group-hover:scale-105 transition duration-700"
        />

        <div class="p-6">
          <h3 class="text-xl font-semibold mb-1">{product.name}</h3>
          <p class="text-neutral-400 mb-4">₹ {product.price}</p>

          <a
            href={`https://wa.me/917305506602?text=I want to order ${product.name}`}
            target="_self"
            class="block w-full text-center py-3 rounded-xl 
                   border border-white/20 hover:bg-white hover:text-black transition"
          >
            ORDER NOW
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
